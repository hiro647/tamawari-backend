# ── PostgreSQL ──────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/tamawari

# ── サーバー ────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ── 認証モード ──────────────────────────────
# "firebase" → Firebase Auth（本番用）
# "dev"      → x-dev-user-id ヘッダーで認証スキップ（開発用）
AUTH_MODE=dev

# ── Firebase（AUTH_MODE=firebase のときのみ必要）──
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Google Maps（任意）─────────────────────
# GOOGLE_MAPS_API_KEY=your-api-key
